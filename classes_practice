// File name - Parameterized class
// Owner - Priyanshu Singh (priyanshus@pulsewavesemi.com)
// Date - 26 Sepetember 2025
  
// Description - This code shows how to use parameters in a class with # in SystemVerilog. You can give different values when creating objects, which makes the class flexible and reusable without changing its code.
  
// ******************************************************** 
  
class base #(int size =8) ;
  
  
  function void display();  
    int arr[] = new[size];
    $display("size of aarray = %d", arr.size());
  endfunction;
endclass



module tb;
  base #(.size(7)) b;
  initial begin
    b = new();
    b.display();
  end
endmodule
