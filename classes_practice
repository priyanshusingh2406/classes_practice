// Description - This code shows how SystemVerilog classes work. The base class myPacket has basic packet fields and a function to display them. The networkPkt class inherits from it and adds extra fields for network packets. It also has its own display function that shows both base and new fields. The testbench creates a networkPkt object and prints all its values, showing how inheritance and method overriding work.

// *********************************************************




class myPacket;
	bit [2:0]  header;
	bit        encode;
	bit [2:0]  mode;
	bit [7:0]  data;
	bit        stop;

	function new (bit [2:0] header = 3'h1, bit [2:0] mode = 5);
		this.header = header;
		this.encode = 0;
		this.mode   = mode;
		this.stop   = 1;
	endfunction

	function display ();
      
		$display ("Header = 0x%0h, Encode = %0b, Mode = 0x%0h, Stop = %0b",
		           this.header, this.encode, this.mode, this.stop);
	endfunction
endclass


class networkPkt extends myPacket;
	bit        parity;
	bit [1:0]  crc;

	function new ();
//       super.new();
		this.parity = 1;
		this.crc = 3;
	endfunction

	function display ();
      super.header= 3'h2;
      super.display();
		$display ("Parity = %0b, CRC = 0x%0h", this.parity, this.crc);
	endfunction
endclass


