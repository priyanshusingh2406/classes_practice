// File name - class Inheritance and casting example
// Owner - Priyanshu Singh (priyanshus@pulsewavesemi.com)
// Date - 26 September 2025

// Description - This SystemVerilog code shows how inheritance and object-oriented programming work. It has a Base class with a show() method and a Child class that inherits from it, adds a property, and overrides show(). The testbench demonstrates creating objects, calling methods, upcasting a child to a base type, and safely accessing child properties using $cast. It helps understand method overriding, upcasting, and downcasting in SystemVerilog.

// ************************************************************************






// Base class
class Base;
   // Base class has no property here
   function void show();
      $display("This is Base class.");
   endfunction
endclass

// Child class inherits from Base
class Child extends Base;
   // Property specific to Child
   int child_property;

   // Constructor to initialize child_property
   function new(int val);
      child_property = val;
   endfunction

   function void show();
      $display("This is Child class with property: %0d", child_property);
   endfunction
endclass


module tb;
   Base base_inst;
   Child child_inst;

   initial begin
      // Create instances
      base_inst = new();
      child_inst = new(42);

      // Accessing base class method through base_inst
      base_inst.show();  // Works fine

      // Accessing child class property through child_inst
      child_inst.show(); // Works fine and shows child_property

      // Now trying to access child property via base_inst
      // This will cause an error because base_inst doesn't know about child_property
      // Uncommenting the next line will result in a compilation error
      // $display("Accessing child property: %0d", base_inst.child_property);

      // Even if base_inst actually points to a Child object, it can't access child_property directly
      base_inst = child_inst; // Upcasting Child to Base

      base_inst.show(); // Calls Base's show(), unless virtual mechanism is used
      
      // Accessing child property requires casting
      if ($cast(child_inst, base_inst)) begin
         $display("Accessing child property after casting: %0d", child_inst.child_property);
      end else begin
         $display("Casting failed");
      end

      $finish;
   end
endmodule









